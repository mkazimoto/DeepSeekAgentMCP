{
  "McpServers": [
    {
      "Name": "totvs-rm-database-mcp-server",
      "Enabled": true,
      "TransportType": "http",
      "Url": "http://localhost:3000/mcp",
      "Headers": {
         "Authorization": "Bearer ${MCP_SERVER_TOKEN}"
      },
      "TimeoutSeconds": 30,
      "AllowedTools": [
        "consulta_saldo_estoque",
        "consulta_preco_produto",
        "consulta_cliente",
        "executa_sql*"
      ] 
    }
  ]
}
