{
  "DeepSeek": {
    "Model": "deepseek-v4-flash",
    "MaxTokens": 4096,
    "Temperature": 0.3,
    "Thinking": {
      "type": "enabled"
    },
    "ReasoningEffort": "high"
  },
  "McpServerConfigPath": "config/mcp-servers.json",
  "WebServer": {
    "Enabled": true,
    "Urls": "http://0.0.0.0:5000",
    "LaunchBrowser": false
  },
  "RateLimiting": {
    "MaxRequestsPerMinute": 30
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5000"]
  },
  "Auth": {
    "Enabled": false,
    "Token": ""
  },
  "Https": {
    "Enabled": false,
    "CertificatePath": ""
  },
  "SessionLimits": {
    "MaxSessionsPerIp": 5
  },
  "HttpClient": {
    "TimeoutSeconds": 300
  },
  "ContinueOnToolError": true,
  "ParallelToolCalls": true,
  "ToolDefinitionsCacheSeconds": 30,
  "SummarizeHistory": false
}
