{
  "DeepSeek": {
    "Model": "deepseek-v4-flash",
    "MaxTokens": 4096,
    "Temperature": 0.3,
    "Thinking": {
      "type": "enabled"
    },
    "ReasoningEffort": "high"
  },
  "McpServerConfigPath": "config/mcp-servers.json",
  "WebServer": {
    "Enabled": true,
    "Urls": "http://0.0.0.0:5000",
    "LaunchBrowser": true
  },
  "RateLimiting": {
    "MaxRequestsPerMinute": 30
  }
}
